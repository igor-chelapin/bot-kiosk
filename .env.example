# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=здесь_твой_токен_от_BotFather

# Telegram Stars Provider Token (получить у BotFather -> Payments)
PROVIDER_TOKEN=здесь_токен_для_stars

# Твой Telegram ID (узнать у @userinfobot)
ADMIN_ID=твой_telegram_id

# Твой username (без @)
ADMIN_USERNAME=твой_юзернейм

# OpenRouter API Key (получить на openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-твой_ключ_здесь

# База данных (можно оставить по умолчанию)
DATABASE_PATH=./bot_database.db

# Настройки OpenRouter
MIN_OR_BALANCE_ALERT=5.0  # Уведомление при балансе ниже $5

# Цены и лимиты
PRICE_PER_1K_TOKENS_RUB=7.5  # Цена за 1000 токенов в рублях
STARS_TO_RUB=1.5             # Курс Stars к рублю
FREE_DAILY_LIMIT_TOKENS=5000  # Бесплатный лимит токенов в день